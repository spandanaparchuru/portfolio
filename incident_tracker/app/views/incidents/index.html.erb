<div class="dashboard-wrapper">

  <!-- OPEN SECTION -->
  <div class="open-section">

    <div class="filter-container">
      <%= form_with url: incidents_path, method: :get, local: true do %>
        <%= select_tag :status,
            options_for_select(
              [["All", ""], ["Open", "Open"], ["InProgress", "InProgress"], ["Resolved", "Resolved"]],
              params[:status]
            ),
            class: "filter-dropdown" %>

        <%= submit_tag "Filter", class: "filter-button" %>
      <% end %>
    </div>

    <div class="section-header d-flex justify-content-between align-items-center">
      <h2 class="section-title text-white">
        Open / In-Progress Incidents
      </h2>

      <%= link_to "Create Incident",
            new_incident_path,
            class: "btn btn-light fw-semibold" %>
    </div>

    <div class="card-container">

      <% @incidents.where(status: ["Open", "InProgress"]).each do |incident| %>

        <div class="incident-card"
             onclick="window.location='<%= incident_path(incident) %>'">

          <div class="incident-title">
            <%= incident.title %>
          </div>

          <div class="incident-status <%= incident.status.downcase %>">
            <%= incident.status %>
          </div>

          <div class="incident-meta">
            <%= incident.updated_at.strftime("%d %b %Y %H:%M") %>
          </div>

          <div class="incident-description">
            <%= truncate(incident.description, length: 90) %>
          </div>

        </div>

      <% end %>

    </div>
  </div>


  <!-- CLOSED SECTION -->
  <div class="closed-section">

    <h3 class="section-title-dark">
      Closed Incidents
    </h3>

    <%= form_with url: bulk_delete_incidents_path,
              method: :post,
              local: true do %>

      <% @incidents.where(status: "Resolved").each do |incident| %>

        <div class="closed-row">

          <div>
            <%= check_box_tag "incident_ids[]", incident.id %>
          </div>

          <div class="closed-title"
               onclick="window.location='<%= incident_path(incident) %>'">
            <%= incident.title %>
          </div>

          <div class="closed-date">
            <%= incident.updated_at.strftime("%d %b %Y %H:%M") %>
          </div>

          <div class="closed-description">
            <%= truncate(incident.description, length: 60) %>
          </div>

        </div>

      <% end %>

      <div class="mt-4">
        <%= submit_tag "Delete Selected",
              class: "btn btn-danger px-4",
              data: { confirm: "Delete selected incidents?" } %>
      </div>

    <% end %>

  </div>

</div>